rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasOrderShape() {
      return request.resource.data.keys().hasAny(['items', 'produtos'])
        && request.resource.data.keys().hasAny(['total', 'valorTotal']);
    }

    match /produtos/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /categorias/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /banners/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /slides/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /colecoes/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /pedidos/{docId} {
      allow create: if hasOrderShape();
      allow read, update, delete: if false;
    }

    match /orders/{docId} {
      allow create: if hasOrderShape();
      allow read, update, delete: if false;
    }

    match /clientes/{docId} {
      allow read, write: if false;
    }

    match /usuarios/{uid} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
    }

    match /customers/{docId} {
      allow read, write: if false;
    }

    match /configuracoes/{docId} {
      allow read, write: if false;
    }

    match /settings/{docId} {
      allow read, write: if false;
    }

    match /cupons/{docId} {
      allow read, write: if false;
    }

    match /notifications/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
